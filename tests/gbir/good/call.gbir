sil_player @p { dollars 100, chance 50, streak 0 }

sil @inc(%0 : $int) -> $int {
bb0:
  %1 = alloca $int
  store %0 to %1 : $int
  %2 = load %1 : $int
  %3 = const_int 1 : $int
  %4 = binop add %2, %3 : $int
  return %4 : $int
}

sil @twice(%0 : $int) -> $int {
bb0:
  %1 = alloca $int
  store %0 to %1 : $int
  %2 = load %1 : $int
  %3 = call @inc(%2) : $int
  %4 = call @inc(%3) : $int
  return %4 : $int
}

sil_scene @main {
bb0:
  %0 = alloca $int
  %1 = const_int 10 : $int
  %2 = call @twice(%1) : $int
  store %2 to %0 : $int
}

