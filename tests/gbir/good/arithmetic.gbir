sil_player @p { dollars 100, chance 50, streak 0 }

sil @compute(%0 : $int, %1 : $int) -> $int {
bb0:
  %2 = alloca $int
  store %0 to %2 : $int
  %3 = alloca $int
  store %1 to %3 : $int
  %4 = alloca $int
  %5 = load %2 : $int
  %6 = load %3 : $int
  %7 = binop add %5, %6 : $int
  store %7 to %4 : $int
  %8 = alloca $int
  %9 = load %4 : $int
  %10 = const_int 2 : $int
  %11 = binop mul %9, %10 : $int
  store %11 to %8 : $int
  %12 = load %8 : $int
  %13 = const_int 1 : $int
  %14 = binop sub %12, %13 : $int
  return %14 : $int
}

sil_scene @main {
bb0:
  %0 = alloca $int
  %1 = const_int 3 : $int
  %2 = const_int 4 : $int
  %3 = call @compute(%1, %2) : $int
  store %3 to %0 : $int
}

