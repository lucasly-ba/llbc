sil_player @p { dollars 100, chance 50, streak 0 }

sil @sign(%0 : $int) -> $int {
bb0:
  %1 = alloca $int
  store %0 to %1 : $int
  %2 = load %1 : $int
  %3 = const_int 0 : $int
  %4 = binop gt %2, %3 : $bool
  cond_br %4, bb1, bb2
bb1:
  %5 = const_int 1 : $int
  return %5 : $int
bb2:
  %6 = const_int 0 : $int
  return %6 : $int
bb3:
}

sil_scene @main {
bb0:
  %0 = alloca $int
  %1 = const_int 5 : $int
  %2 = call @sign(%1) : $int
  store %2 to %0 : $int
}

