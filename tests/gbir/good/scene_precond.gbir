sil_player @p { dollars 100, chance 50, streak 0 }

sil_scene @boss max 2 requires %2 {
pre0:
  %0 = const_int 5 : $int
  %1 = const_int 3 : $int
  %2 = binop gt %0, %1 : $bool
bb0:
  %3 = alloca $int
  %4 = const_int 2 : $int
  store %4 to %3 : $int
}

sil_scene @lobby max 4 {
bb0:
  %0 = alloca $int
  %1 = const_int 1 : $int
  store %1 to %0 : $int
}

sil_scene @main {
bb0:
  %0 = alloca $int
  %1 = const_int 1 : $int
  store %1 to %0 : $int
}

