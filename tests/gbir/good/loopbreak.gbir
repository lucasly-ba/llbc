sil_player @p { dollars 100, chance 50, streak 0 }

sil @count(%0 : $int) -> $int {
bb0:
  %1 = alloca $int
  store %0 to %1 : $int
  br bb1
bb1:
  %2 = load %1 : $int
  %3 = const_int 10 : $int
  %4 = binop gt %2, %3 : $bool
  cond_br %4, bb3, bb4
bb3:
  br bb2
bb6:
  br bb5
bb4:
  br bb5
bb5:
  %5 = load %1 : $int
  %6 = const_int 1 : $int
  %7 = binop add %5, %6 : $int
  store %7 to %1 : $int
  br bb1
bb2:
  %8 = load %1 : $int
  return %8 : $int
}

sil_scene @main {
bb0:
  %0 = alloca $int
  %1 = const_int 0 : $int
  %2 = call @count(%1) : $int
  store %2 to %0 : $int
}

